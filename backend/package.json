{
  "name": "outlook-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.6.0",
    "npm": "11.5.1"
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/app.ts",
    "build": "tsc",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "db:compute-scores": "tsx scripts/compute-scores.ts"
  },
  "dependencies": {
    "@trpc/server": "^11.8.1",
    "cache-manager": "^6.4.2",
    "config": "^4.1.1",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.1",
    "express": "^5.1.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.2.0",
    "node-cron": "^3.0.3",
    "pg": "^8.13.3",
    "superjson": "^2.2.2",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.11",
    "@vitest/eslint-plugin": "^1.6.10",
    "drizzle-kit": "^0.31.3",
    "eslint": "^10.0.3",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.2.4"
  },
  "prettier": {
    "trailingComma": "all",
    "tabWidth": 2,
    "semi": false,
    "singleQuote": true
  }
}
